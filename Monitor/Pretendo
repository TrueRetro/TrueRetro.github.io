<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>True Retro Monitor Hub</title>
    <style>
        /* Pure Black Background and Font Styling */
        body {
            background-color: #000000;
            color: #FFFFFF;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; /* Modern, clean font */
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        /* Frosted Glass Header */
        header {
            width: 100%;
            height: 80px;
            position: fixed; /* Keep it at the top */
            top: 0;
            z-index: 100; /* Ensure it stays above content */
            backdrop-filter: blur(10px) saturate(180%); /* The frosted effect */
            -webkit-backdrop-filter: blur(10px) saturate(180%);
            background-color: rgba(17, 25, 40, 0.5); /* Semi-transparent background */
            display: flex;
            align-items: center;
            justify-content: space-between; /* Space elements across the bar */
            padding: 0 40px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1); /* Subtle bottom line */
        }

        /* Center the Header Title */
        .header-title {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            font-size: 1.8rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* Stemless Down Arrow on the Left */
        .header-icon {
            font-size: 2rem;
            cursor: pointer;
            transition: color 0.3s ease;
        }

        .header-icon:hover {
            color: #3498db; /* Blue accent on hover */
        }

        /* Content Container (shifted down for fixed header) */
        main {
            margin-top: 120px; /* Space below header */
            width: 90%;
            max-width: 1200px;
            display: flex;
            flex-direction: column;
            gap: 30px; /* Space between cards */
            padding-bottom: 40px;
        }

        /* Base Card Styling */
        .card {
            background-color: #111111; /* Very dark gray for subtle contrast */
            border-radius: 20px; /* Rounded corners for all cards */
            padding: 30px;
            border: 1px solid #222222; /* Define edges on pure black */
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            text-decoration: none; /* Make card links look like containers */
            color: inherit;
        }

        /* Hover effect for the linkable Pretendo card */
        .card-link:hover {
            transform: translateY(-5px); /* Lift card slightly */
            box-shadow: 0 10px 20px rgba(52, 152, 219, 0.1); /* Subtle blue glow */
            border-color: #333333;
        }

        /* Top Card (Pretendo) Specific Styling */
        .pretendo-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
        }

        /* Style for the pretendo.png image */
        .pretendo-card img {
            max-height: 80px;
            width: auto;
        }

        /* Placeholder Card Styling (the other 4) */
        .placeholder-card {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            opacity: 0.6; /* Slight transparency for 'not yet available' feel */
            border-style: dashed; /* Indicate it's a placeholder */
        }

        .placeholder-card h2 {
            margin-top: 0;
            color: #888888;
        }

        .placeholder-card p {
            color: #666666;
            margin-bottom: 0;
        }

        /* Utility classes for typography */
        h2 {
            margin-top: 0;
            font-size: 1.5rem;
            color: #FFFFFF;
        }

        p {
            margin: 10px 0;
            color: #AAAAAA;
            line-height: 1.6;
        }
    </style>
</head>
<body>

    <header>
        <div class="header-icon">▼</div> <div class="header-title">True Retro</div>
    </header>

    <main>
        
        <a href="/monitor/pretendo/index.html" class="card card-link pretendo-card">
            <div>
                <h2>Pretendo Network Monitor</h2>
                <p>Real-time server health and player counts for Nintendo Revival Services.</p>
            </div>
            <img src="pretendo.png" alt="Pretendo Logo">
        </a>

        <div class="card placeholder-card">
            <h2>Future Monitor Station</h2>
            <p>Monitors for other networks (e.g., Wiimmfi or Insignia) will be added here as the hub expands.</p>
        </div>

        <div class="card placeholder-card">
            <h2>Future Monitor Station</h2>
            <p>This slot is reserved for upcoming preservation projects.</p>
        </div>

        <div class="card placeholder-card">
            <h2>Future Monitor Station</h2>
            <p>This slot is reserved for upcoming preservation projects.</p>
        </div>

        <div class="card placeholder-card">
            <h2>Future Monitor Station</h2>
            <p>This slot is reserved for upcoming preservation projects.</p>
        </div>

    </main>

</body>
</html>
